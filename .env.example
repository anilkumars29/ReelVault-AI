# 🎬 ReelVault Environment Variables Template
# Duplicate this file, rename it to '.env', and insert your real credentials below.

# Telegram Bot API Token (Obtained via @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Notion Integration Configuration (Optional Cloud Sync)
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_page_id_here